{
  "name": "mc-connects-website",
  "version": 2,
  "build": {
    "root": ".",
    "output": "."
  },
  "routes": [
    {
      "src": "/saas-solutions/(.*)",
      "dest": "/saas-solutions/$1"
    },
    {
      "src": "/turnkey-solutions/(.*)",
      "dest": "/turnkey-solutions/$1"
    },
    {
      "src": "/web-home/(.*)",
      "dest": "/web-home/$1"
    },
    {
      "src": "/liquidity/(.*)",
      "dest": "/liquidity/$1"
    },
    {
      "src": "/intelligence/(.*)",
      "dest": "/intelligence/$1"
    },
    {
      "src": "/components/(.*)",
      "dest": "/components/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "**/*.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "**/*.jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "**/*.jpeg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
